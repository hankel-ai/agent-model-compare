# Optional configuration for agent-orchestrator.
# Copy to .env and edit. .env is gitignored.
#
# All variables below are optional. If a variable is unset or empty,
# the related feature is disabled — the orchestrator will still run,
# it just won't use that capability.

# ── LiteLLM proxy (for non-Claude models) ─────────────────────────
# If unset, only models listed in config/config.yaml `claude_models`
# will work. Requesting any other model will error out cleanly.
LITELLM_BASE_URL=
LITELLM_MASTER_KEY=

# ── Outbound HTTPS proxy ──────────────────────────────────────────
# Injected into every agent subprocess. If unset, no proxy is used.
HTTPS_PROXY=

# ── Extra CA cert bundle for Node-based tools (e.g. Claude Code CLI) ──
# Path can be absolute or relative to the project root. If unset, the
# system CA bundle is used.
NODE_EXTRA_CA_CERTS=

# ── Optional: NVIDIA NIM API key (only used by list_models.py) ────
NVIDIA_NIM_API_KEY=
